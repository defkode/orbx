#!/usr/bin/env bash
#
# orbx — per-project OrbStack sandboxes.
# See: https://github.com/defkode/orbx

# Require bash >= 4 BEFORE any bash-4-only syntax runs at load time (declare -g/-A
# appear further down). macOS ships bash 3.2, so this guard is POSIX-compatible.
if [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
  printf 'orbx: requires bash >= 4 (have %s). macOS: brew install bash\n' "${BASH_VERSION:-unknown}" >&2
  exit 1
fi

ORBX_VERSION="0.1.0"

# Replaced at install time by the Homebrew formula. Unstamped in a git checkout.
ORBX_BUNDLED_TEMPLATE_DIR="@TEMPLATE_DIR@"

orbx::version() { printf 'orbx %s\n' "$ORBX_VERSION"; }

orbx::sanitize_name() {
  local raw="$1" out
  out="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9-' '-')"
  out="$(printf '%s' "$out" | sed -E 's/-+/-/g; s/^-+//; s/-+$//')"
  printf '%s' "$out"
}

orbx::derive_name() {
  local name
  name="$(orbx::sanitize_name "$(basename "$PWD")")"
  if [[ -z "$name" ]]; then
    printf 'orbx: cannot derive a machine name from %s; pass --name\n' "$PWD" >&2
    return 1
  fi
  printf '%s' "$name"
}

orbx::trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"   # left-trim
  s="${s%"${s##*[![:space:]]}"}"   # right-trim
  printf '%s' "$s"
}

orbx::parse_config_file() {
  local file="$1" line key val
  [[ -f "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"                 # drop comments (values cannot contain '#')
    [[ "$line" == *"="* ]] || continue
    key="$(orbx::trim "${line%%=*}")"
    val="$(orbx::trim "${line#*=}")"
    [[ -n "$key" ]] || continue
    printf '%s=%s\n' "$key" "$val"
  done < "$file"
}

orbx::effective_config() {
  declare -A cfg=( [template]=default [image]=ubuntu:26.04 [arch]="" [mount]=true )
  local src k v
  for src in "${ORBX_GLOBAL_CONFIG:-$HOME/.orbx/config}" "$PWD/.orbxrc"; do
    while IFS='=' read -r k v; do
      [[ -n "$k" ]] && cfg["$k"]="$v"
    done < <(orbx::parse_config_file "$src")
  done
  for k in "${!cfg[@]}"; do
    printf '%s=%s\n' "$k" "${cfg[$k]}"
  done | sort
}

orbx::mount_target() {
  local host="${1:-$PWD}" home="${HOME%/}" user="${USER:-$(id -un)}"
  if [[ "$host" == "$home"/* ]]; then
    printf '/home/%s/%s' "$user" "${host#"$home"/}"
  else
    printf '%s' "$host"
  fi
}

# Full "host:target" spec for the automatic $PWD mount.
orbx::mount_spec() {
  local host="${1:-$PWD}"
  printf '%s:%s' "$host" "$(orbx::mount_target "$host")"
}

orbx::script_dir() {
  local src="${BASH_SOURCE[0]}" dir
  while [[ -h "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"   # re-anchor relative symlink targets
  done
  ( cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd )
}

orbx::resolve_template() {
  local name="$1" dir
  for dir in \
    "${ORBX_TEMPLATE_DIR:-}" \
    "$HOME/.orbx/templates" \
    "$ORBX_BUNDLED_TEMPLATE_DIR" \
    "$(orbx::script_dir)/../templates"
  do
    [[ -n "$dir" ]] || continue
    if [[ -f "$dir/$name.yaml" ]]; then
      printf '%s' "$dir/$name.yaml"
      return 0
    fi
  done
  printf 'orbx: template %q not found. Run: orbx templates\n' "$name" >&2
  return 1
}

# Resolved run state (populated by orbx::resolve_context).
declare -g ORBX_NAME ORBX_IMAGE ORBX_ARCH ORBX_TEMPLATE ORBX_TEMPLATE_PATH ORBX_MOUNT_ON ORBX_DRYRUN ORBX_YES
declare -ga ORBX_MOUNTS ORBX_CREATE_CMD

orbx::resolve_context() {
  # Reads effective config, applies parsed flags (already in the ORBX_FLAG_* vars),
  # and populates the ORBX_* run-state globals.
  local k v
  ORBX_TEMPLATE=default; ORBX_IMAGE=ubuntu:26.04; ORBX_ARCH=""; ORBX_MOUNT_ON=true
  while IFS='=' read -r k v; do
    case "$k" in
      template) ORBX_TEMPLATE="$v" ;;
      image)    ORBX_IMAGE="$v" ;;
      arch)     ORBX_ARCH="$v" ;;
      mount)    ORBX_MOUNT_ON="$v" ;;
      name)     ORBX_NAME="$v" ;;
    esac
  done < <(orbx::effective_config)

  # Flag overrides (empty = not set).
  [[ -n "${ORBX_FLAG_TEMPLATE:-}" ]] && ORBX_TEMPLATE="$ORBX_FLAG_TEMPLATE"
  [[ -n "${ORBX_FLAG_IMAGE:-}" ]]    && ORBX_IMAGE="$ORBX_FLAG_IMAGE"
  [[ -n "${ORBX_FLAG_ARCH:-}" ]]     && ORBX_ARCH="$ORBX_FLAG_ARCH"
  [[ -n "${ORBX_FLAG_NAME:-}" ]]     && ORBX_NAME="$ORBX_FLAG_NAME"
  [[ "${ORBX_FLAG_NO_MOUNT:-}" == "1" ]] && ORBX_MOUNT_ON=false

  [[ -n "${ORBX_NAME:-}" ]] || ORBX_NAME="$(orbx::derive_name)"
  ORBX_TEMPLATE_PATH="$(orbx::resolve_template "$ORBX_TEMPLATE")"

  # Assemble the mount list: auto $PWD mount (unless disabled) + explicit --mount.
  ORBX_MOUNTS=()
  [[ "$ORBX_MOUNT_ON" == "true" ]] && ORBX_MOUNTS+=("$(orbx::mount_spec)")
  local m
  if (( ${#ORBX_FLAG_MOUNTS[@]} )); then
    for m in "${ORBX_FLAG_MOUNTS[@]}"; do
      [[ -n "$m" ]] && ORBX_MOUNTS+=("$m")
    done
  fi
}

orbx::build_create_cmd() {
  ORBX_CREATE_CMD=(orb create -c "$ORBX_TEMPLATE_PATH" --isolated)
  [[ -n "$ORBX_ARCH" ]] && ORBX_CREATE_CMD+=(--arch "$ORBX_ARCH")
  local m
  if (( ${#ORBX_MOUNTS[@]} )); then
    for m in "${ORBX_MOUNTS[@]}"; do ORBX_CREATE_CMD+=(--mount "$m"); done
  fi
  ORBX_CREATE_CMD+=("$ORBX_IMAGE" "$ORBX_NAME")
}

orbx::die() { printf 'orbx: %s\n' "$*" >&2; exit 1; }

orbx::parse_flags() {
  ORBX_FLAG_MOUNTS=()
  ORBX_DRYRUN=0; ORBX_YES=0; ORBX_FORCE=0
  ORBX_ARGS=()
  while (( $# )); do
    case "$1" in
      --name)     ORBX_FLAG_NAME="$2"; shift 2 ;;
      --template) ORBX_FLAG_TEMPLATE="$2"; shift 2 ;;
      --image)    ORBX_FLAG_IMAGE="$2"; shift 2 ;;
      --arch)     ORBX_FLAG_ARCH="$2"; shift 2 ;;
      --mount)    ORBX_FLAG_MOUNTS+=("$2"); shift 2 ;;
      --no-mount) ORBX_FLAG_NO_MOUNT=1; shift ;;
      --dry-run)  ORBX_DRYRUN=1; shift ;;
      --yes|-y)   ORBX_YES=1; shift ;;
      --force)    ORBX_FORCE=1; shift ;;
      --)         shift; while (( $# )); do ORBX_ARGS+=("$1"); shift; done ;;
      -*)         orbx::die "unknown flag: $1" ;;
      *)          ORBX_ARGS+=("$1"); shift ;;
    esac
  done
}

orbx::require_orb() {
  local bin="${ORBX_ORB_BIN:-orb}"
  command -v "$bin" >/dev/null 2>&1 || orbx::die \
    "the '$bin' CLI is required. Install OrbStack: https://orbstack.dev"
}

orbx::usage() {
  cat <<'EOF'
orbx — per-project OrbStack Rails + Claude Code sandboxes

USAGE
  orbx [command] [flags]

COMMANDS
  (none)        Bring this project's sandbox up (create if needed) and shell in
  up            Create/start + provision, wait until ready — don't shell in
  shell         Open a shell in the sandbox
  run <cmd…>    Run a command inside (flags need --: orbx run -- bin/rails -e prod)
  status        Show state, provisioning status, template, and mount
  logs          Tail the provisioning log
  stop          Stop the machine (keeps data)
  down          Delete this sandbox permanently (asks first; --yes to skip)
  list          List all machines + status
  ip            Print this sandbox's IP
  templates     List available templates
  config        Show the effective config
  init          Scaffold ./.orbxrc in this project (--force to overwrite)

FLAGS
  --name <name>   Machine name (default: current folder, sanitized)
  --mount <spec>  Extra host:target mount (repeatable)
  --no-mount      Disable the automatic $PWD mount
  --template <n>  Template name (default: from config, else "default")
  --image <ref>   Base image (default: ubuntu:26.04)
  --arch <arch>   amd64 | arm64 (default: native)
  --dry-run       Print the orb command that would run, then exit
  --yes, -y       Assume yes for confirmations
  --force         Overwrite when scaffolding (orbx init)
  -h, --help      Show this help
  --version       Show version
EOF
}

orbx::main() {
  case "${1:-}" in
    --version) orbx::version; return 0 ;;
    -h|--help|help) orbx::usage; return 0 ;;
  esac
  orbx::require_orb
  orbx::parse_flags "$@"
  local cmd="${ORBX_ARGS[0]:-shell-default}"
  if (( ${#ORBX_ARGS[@]} > 1 )); then set -- "${ORBX_ARGS[@]:1}"; else set --; fi
  case "$cmd" in
    shell-default) orbx::cmd_default ;;
    up)        orbx::cmd_up ;;
    shell)     orbx::cmd_shell ;;
    run)       orbx::cmd_run "$@" ;;
    status)    orbx::cmd_status ;;
    logs)      orbx::cmd_logs ;;
    stop)      orbx::cmd_stop ;;
    down)      orbx::cmd_down ;;
    list|ls)   orbx::cmd_list ;;
    ip)        orbx::cmd_ip ;;
    templates) orbx::cmd_templates ;;
    config)    orbx::cmd_config ;;
    init)      orbx::cmd_init ;;
    *)         orbx::die "unknown command: $cmd (try: orbx --help)" ;;
  esac
}

orbx::cmd_up() {
  orbx::resolve_context
  orbx::build_create_cmd
  if [[ "$ORBX_DRYRUN" == "1" ]]; then
    printf '%s ' "${ORBX_CREATE_CMD[@]}"; printf '\n'
    return 0
  fi
  orbx::ensure_up   # implemented in Task 10
}

orbx::machine_exists()  { orb list -q        | grep -Fxq -- "$1"; }
orbx::machine_running() { orb list -r -q     | grep -Fxq -- "$1"; }

orbx::wait_ready() {
  local name="$1"
  local timeout="${ORBX_READY_TIMEOUT:-1200}"
  local interval="${ORBX_POLL_INTERVAL:-5}"
  local delay="${ORBX_POLL_DELAY:-2}" waited=0 status
  (( delay > 0 )) && sleep "$delay"
  while :; do
    status="$(orb -m "$name" -u root cat /etc/sandbox-status 2>/dev/null || true)"
    case "$status" in
      ready)  return 0 ;;
      failed) printf 'orbx: provisioning failed. See: orbx logs\n' >&2; return 1 ;;
    esac
    (( waited >= timeout )) && break
    (( interval > 0 )) && sleep "$interval"
    waited=$(( waited + (interval > 0 ? interval : 1) ))
  done
  printf 'orbx: timed out after %ss waiting for ready. See: orbx logs\n' "$timeout" >&2
  return 1
}

orbx::ensure_up() {
  if orbx::machine_exists "$ORBX_NAME"; then
    if ! orbx::machine_running "$ORBX_NAME"; then
      orb start "$ORBX_NAME"
    fi
  else
    printf 'orbx: creating %s (mount %s)\n' "$ORBX_NAME" "${ORBX_MOUNTS[0]:-none}" >&2
    "${ORBX_CREATE_CMD[@]}"
  fi
  orbx::wait_ready "$ORBX_NAME"
}

orbx::cmd_shell() {
  orbx::resolve_context
  orbx::build_create_cmd
  orbx::ensure_up
  if [[ "$ORBX_MOUNT_ON" == "true" ]]; then
    # shellcheck disable=SC2016  # $1/$SHELL expand in the VM shell, not locally
    orb -m "$ORBX_NAME" bash -lc 'cd "$1" && exec "$SHELL" -l' _ "$(orbx::mount_target)"
  else
    # No auto-mount: the project dir doesn't exist in the VM, so open in $HOME.
    # shellcheck disable=SC2016  # $SHELL expands in the VM shell, not locally
    orb -m "$ORBX_NAME" bash -lc 'exec "$SHELL" -l'
  fi
}

orbx::cmd_default() { orbx::cmd_shell; }

orbx::cmd_run() {
  [[ $# -gt 0 ]] || orbx::die "run needs a command (e.g. orbx run bin/dev)"
  orbx::resolve_context
  orbx::build_create_cmd
  orbx::ensure_up
  if [[ "$ORBX_MOUNT_ON" == "true" ]]; then
    # shellcheck disable=SC2016  # $1/$@ expand in the VM shell, not locally
    orb -m "$ORBX_NAME" bash -lc 'cd "$1" && shift && exec "$@"' _ "$(orbx::mount_target)" "$@"
  else
    # shellcheck disable=SC2016  # $@ expands in the VM shell, not locally
    orb -m "$ORBX_NAME" bash -lc 'exec "$@"' _ "$@"
  fi
}

orbx::cmd_stop()  { orbx::resolve_context; orb stop  "$ORBX_NAME"; }
orbx::cmd_list()  { orb list; }
orbx::cmd_logs()  { orbx::resolve_context; orb -m "$ORBX_NAME" tail -f /var/log/sandbox-provision.log; }

orbx::cmd_down() {
  orbx::resolve_context
  if [[ "$ORBX_YES" != "1" ]]; then
    [[ -t 0 ]] || orbx::die "refusing to delete non-interactively; pass --yes"
    printf 'Delete sandbox %q? Data inside the VM is lost (your folder is safe). [y/N] ' "$ORBX_NAME" >&2
    local ans; read -r ans || ans=""
    [[ "$ans" == [yY]* ]] || { printf 'aborted\n' >&2; return 1; }
  fi
  orb delete -f "$ORBX_NAME"
}

# Extract a flat JSON string field without a jq dependency.
orbx::json_field() {
  sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p" | head -1
}

orbx::cmd_ip() {
  orbx::resolve_context
  local ip; ip="$(orb info "$ORBX_NAME" -f json | orbx::json_field ip4 || true)"
  [[ -n "$ip" ]] || orbx::die "could not determine IP for $ORBX_NAME"
  printf '%s\n' "$ip"
}

orbx::cmd_status() {
  orbx::resolve_context
  local state="absent" prov="-" ip="-"
  if orbx::machine_exists "$ORBX_NAME"; then
    state="stopped"; orbx::machine_running "$ORBX_NAME" && state="running"
    prov="$(orb -m "$ORBX_NAME" -u root cat /etc/sandbox-status 2>/dev/null || echo unknown)"
    ip="$(orb info "$ORBX_NAME" -f json 2>/dev/null | orbx::json_field ip4 || true)"
    [[ -n "$ip" ]] || ip="-"
  fi
  printf '%s\t%s\tprovisioning: %s\tip: %s\ttemplate: %s\tmount: %s\n' \
    "$ORBX_NAME" "$state" "$prov" "$ip" "$ORBX_TEMPLATE" "$(orbx::mount_target)"
}

orbx::cmd_templates() {
  orbx::resolve_context 2>/dev/null || true
  local dir name seen=" "
  printf '%-16s %s\n' NAME SOURCE
  for dir in "$HOME/.orbx/templates" "$ORBX_BUNDLED_TEMPLATE_DIR" "$(orbx::script_dir)/../templates"; do
    [[ -d "$dir" ]] || continue
    for f in "$dir"/*.yaml; do
      [[ -e "$f" ]] || continue
      name="$(basename "$f" .yaml)"
      [[ "$seen" == *" $name "* ]] && continue
      seen+="$name "
      local src="user"; [[ "$dir" == "$HOME/.orbx/templates" ]] || src="built-in"
      local mark=""; [[ "$name" == "${ORBX_TEMPLATE:-default}" ]] && mark=" (active)"
      printf '%-16s %s%s\n' "$name" "$src" "$mark"
    done
  done
}

orbx::cmd_config() {
  printf '# effective config (files: %s, ./.orbxrc)\n' "${ORBX_GLOBAL_CONFIG:-$HOME/.orbx/config}"
  orbx::effective_config
}

orbx::cmd_init() {
  local target="$PWD/.orbxrc"
  if [[ -e "$target" && "${ORBX_FORCE:-0}" != "1" ]]; then
    orbx::die ".orbxrc already exists (use: orbx init --force)"
  fi
  cat > "$target" <<'EOF'
# orbx project config — committed, shared with your team.
template = default
# image  = ubuntu:26.04
# name   = my-machine     # default: the sanitized folder name
# mount  = false          # set false to skip auto-mounting $PWD
EOF
  printf 'wrote %s\n' "$target"
}

# Run main only when executed directly; do nothing when sourced (tests).
# (Unit tests run under bats' bash, which must also be >= 4 — see Task 1 Step 2.)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail
  orbx::main "$@"
fi
